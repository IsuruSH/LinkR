# Copy to .env before running: `cp .env.example .env` (or `make up`, which does it for you).
# Every variable the stack reads is listed here. .env is gitignored.

# ---- Postgres ----
POSTGRES_USER=linkr
POSTGRES_PASSWORD=linkr_dev_password        # override in any real environment
POSTGRES_DB=linkr
POSTGRES_PORT=5432                          # host port, dev convenience only

# ---- Redis ----
REDIS_PORT=6379                             # host port, dev convenience only

# ---- Backend ----
BACKEND_PORT=8080
APP_ENV=development                         # development | production
LOG_LEVEL=info                              # debug | info | warn | error

# Base URL used to render short links back to clients (http://host/{code}).
PUBLIC_BASE_URL=http://localhost:8080

# JWT. MUST be overridden outside dev. Minimum 32 bytes — the server refuses to boot otherwise.
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_bytes
JWT_TTL=24h

# Postgres pool. See DECISIONS.md for the sizing rationale.
DB_MAX_CONNS=20
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=30m
DB_MAX_CONN_IDLE_TIME=5m

# Redis cache
CACHE_TTL=24h                               # code -> link
CACHE_NEGATIVE_TTL=60s                      # cached 404, blunts enumeration scans

# Async click worker
CLICK_BUFFER_SIZE=10000                     # bounded; when full we drop and count
CLICK_WORKERS=4
CLICK_BATCH_SIZE=100                        # flush at N events...
CLICK_FLUSH_INTERVAL=500ms                  # ...or on this tick, whichever fires first
CLICK_DRAIN_TIMEOUT=5s                      # bounded drain on SIGTERM

# HTTP
REQUEST_TIMEOUT=10s
CORS_ALLOWED_ORIGINS=http://localhost:3000  # comma-separated

# ---- Frontend ----
FRONTEND_PORT=3000

# Browser-visible. Baked at build time by Next (NEXT_PUBLIC_* is inlined), so it is
# both a compose build arg and a runtime env. This is the address the BROWSER uses
# to follow a short link, so it must be reachable from the host.
#
# The Next server reaches the API at BACKEND_INTERNAL_URL (http://backend:8080),
# set in docker-compose.yml — inside the container, localhost is the frontend.
NEXT_PUBLIC_API_URL=http://localhost:8080
