# Single source of configuration for BOTH stacks. Copy to .env: `cp .env.example .env`.
# .env is gitignored. `make up` copies it for you.
#
#   Local dev:    docker compose up --build                    (uses docker-compose.yml)
#   Production:   docker compose -f docker-compose.prod.yml up -d --build
#
# The defaults below run the DEV stack out of the box. For PRODUCTION you only
# need to change the four values in the first block — the production compose
# DERIVES the public URLs, DATABASE_URL, REDIS_URL, APP_ENV and TRUST_PROXY_HEADERS
# from them, so you never set the same value twice.

# ============================================================================
# PRODUCTION — you MUST set these before deploying. Dev works without touching them.
# ============================================================================

# The one public URL the app is served on. The production compose fans this out
# to PUBLIC_BASE_URL, APP_URL, CORS_ALLOWED_ORIGINS and NEXT_PUBLIC_API_URL.
# Use a domain or the EC2 public DNS — NEVER an IP you might lose. No trailing slash.
#   e.g. https://links.example.com   or   http://ec2-1-2-3-4.compute.amazonaws.com
# Left empty on purpose: the production stack refuses to start until it is set.
APP_ORIGIN=

# Signing key for session JWTs. Minimum 32 bytes; the server refuses to boot in
# production if this is still the example value. Generate one:
#   openssl rand -base64 48
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_bytes

# Database password. Change it for any real deployment.
POSTGRES_PASSWORD=linkr_dev_password

# Seed the demo account (demo@linkr.dev) on first boot. Handy for a live demo;
# set false for a real deployment. No-ops once the database has users.
SEED_DEMO_DATA=false

# Container images (production). CI builds and pushes backend/frontend to GHCR;
# the host pulls them (no compiler runs on the box). IMAGE_TAG pins a version —
# "latest", or a commit SHA to roll back to a specific build. IMAGE_PREFIX only
# needs changing if you forked to a different GHCR owner.
IMAGE_TAG=latest
# IMAGE_PREFIX=ghcr.io/isurush/linkr

# ============================================================================
# Postgres / Redis
# ============================================================================
POSTGRES_USER=linkr
POSTGRES_DB=linkr
POSTGRES_PORT=5432   # host port — DEV ONLY (production publishes nothing but Nginx)
REDIS_PORT=6379      # host port — DEV ONLY

# ============================================================================
# Backend
# ============================================================================
BACKEND_PORT=8080
APP_ENV=development   # dev value; production compose forces "production"
LOG_LEVEL=info        # debug | info | warn | error
JWT_TTL=24h
BACKEND_REPLICAS=3

# Postgres pool (see DECISIONS.md for the sizing rationale).
DB_MAX_CONNS=20
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=30m
DB_MAX_CONN_IDLE_TIME=5m

# Redis cache
CACHE_TTL=24h
CACHE_NEGATIVE_TTL=60s

# Async click worker
CLICK_BUFFER_SIZE=10000
CLICK_WORKERS=4
CLICK_BATCH_SIZE=100
CLICK_FLUSH_INTERVAL=500ms
CLICK_DRAIN_TIMEOUT=5s

# Rate limiting, fixed one-minute windows. Fails open if Redis is down. See DECISIONS.md.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_MINUTE=30          # POST /api/links, per authenticated user
RATE_LIMIT_AUTH_PER_MINUTE=10     # /api/auth/*, per client IP (brute-force guard)

REQUEST_TIMEOUT=10s

# ============================================================================
# Derived in production — leave the dev defaults; do NOT duplicate APP_ORIGIN here.
# ----------------------------------------------------------------------------
# In the DEV stack these localhost values are used as-is. In PRODUCTION the
# compose file overrides every one of them from APP_ORIGIN above, so setting them
# by hand would be duplication (and would drift). They stay here only so the dev
# stack — which does not know APP_ORIGIN — has correct values.
# ============================================================================
PUBLIC_BASE_URL=http://localhost:8080         # prod: = APP_ORIGIN
APP_URL=http://localhost:3000                 # prod: = APP_ORIGIN
CORS_ALLOWED_ORIGINS=http://localhost:3000    # prod: = APP_ORIGIN
NEXT_PUBLIC_API_URL=http://localhost:8080     # prod: = APP_ORIGIN (baked at build)
TRUST_PROXY_HEADERS=false                     # prod: forced true (behind Nginx)
FRONTEND_PORT=3000                            # host port — DEV ONLY
